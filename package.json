{
  "name": "local-agent",
  "productName": "local-agent",
  "version": "1.0.0",
  "description": "Electron shell for namu local agent — loads the externally deployed Next.js frontend over HTTPS",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "dev": "APP_URL=http://localhost:3000 electron-forge start",
    "dev:ssl": "APP_URL=https://localhost:3000 TRUST_SELF_SIGNED=true electron-forge start",
    "dev:with-next": "concurrently -k -n NEXT,ELECTRON -c cyan,yellow \"npm run _next:dev\" \"npm run _electron:wait\"",
    "dev:with-next:ssl": "concurrently -k -n NEXT,ELECTRON -c cyan,yellow \"npm run _next:dev\" \"npm run _electron:wait:ssl\"",
    "_next:dev": "cd ../namu-localAgent && npm run dev",
    "_electron:wait": "wait-on http://localhost:3000 && npm run dev",
    "_electron:wait:ssl": "wait-on https://localhost:3000 --timeout 60000 && npm run dev:ssl",
    "build": "electron-forge package",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "rag:test-kb": "node scripts/rag-ingest-and-test.mjs",
    "hwpx:server": "bash ../hwpx-server/run-server.sh",
    "hwpx-server": "npm run hwpx:server",
    "hwpx:e2e": "bash ../hwpx-server/run-e2e.sh",
    "hwpx:e2e:all": "bash ../scripts/e2e-hwpx.sh"
  },
  "keywords": [],
  "author": {
    "name": "Namu-iAPT-Enterprise",
    "email": "namu.github@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "concurrently": "^9.1.2",
    "electron": "^41.1.1",
    "eslint": "^8.57.1",
    "typescript": "^6.0.2",
    "vite": "^5.4.21",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "docx": "^9.6.1",
    "electron-squirrel-startup": "^1.0.1",
    "lightningcss": "^1.32.0",
    "lucide-react": "^1.7.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^4.10.38",
    "pptxgenjs": "^4.0.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remend": "^1.3.0",
    "tailwindcss": "^4.2.2",
    "xlsx": "^0.18.5"
  }
}
